---
interface Props {
  variant?: 'primary' | 'dark' | 'secondary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  class: extraClass = '',
} = Astro.props;

const baseClasses =
  'inline-block px-6 py-2.5 rounded-md text-base font-medium font-sans no-underline transition-opacity hover:opacity-90 focus-visible:outline-[3px] focus-visible:outline-offset-2';

const variantClasses: Record<string, string> = {
  primary: 'bg-sunset-coral text-sea-salt',
  dark: 'bg-cliff-deep text-sea-salt',
  secondary: 'bg-transparent text-cliff-deep border border-[1.5px] border-cliff-deep',
  ghost: 'bg-transparent text-cliff-deep border border-[1.5px] border-border',
};

const classes = [baseClasses, variantClasses[variant], extraClass].join(' ');
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}

---
interface Props {
  status: 'open' | 'seasonal' | 'closed';
  seasonNote?: string;
}

const { status, seasonNote } = Astro.props;

const labels: Record<string, string> = {
  open: 'Open',
  seasonal: 'Seasonal',
  closed: 'Closed',
};
---

<span class:list={['badge', `badge-${status}`, 'inline-flex items-center gap-1.5 text-sm font-medium px-2.5 py-0.5 rounded-full']}>
  {status === 'open' && (
    <span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
  )}
  {labels[status]}
</span>
{seasonNote && status === 'seasonal' && (
  <span class="text-sm text-amber-700 ml-2">{seasonNote}</span>
)}

---
import { getCollection } from 'astro:content';

const configs = await getCollection('siteConfig');
const config = configs[0]?.data;
---

<footer class="bg-volcanic text-sky-water mt-16">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- About -->
      <div>
        <h2 class="font-serif text-sea-salt text-lg mb-3">Los Gigantes Guide</h2>
        <p class="text-sm leading-relaxed opacity-80">
          Local tips, honest reviews, and hidden spots — by someone who lives here.
          Everything you need for a holiday or a longer stay in Los Gigantes, Tenerife.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-sans font-semibold text-sea-salt text-sm uppercase tracking-wider mb-3">
          Explore
        </h3>
        <ul class="flex flex-col gap-2 list-none">
          <li><a href="/activities/" class="text-sm text-sky-water hover:text-sea-salt no-underline opacity-80 hover:opacity-100">Things to do</a></li>
          <li><a href="/restaurants/" class="text-sm text-sky-water hover:text-sea-salt no-underline opacity-80 hover:opacity-100">Restaurants</a></li>
          <li><a href="/services/" class="text-sm text-sky-water hover:text-sea-salt no-underline opacity-80 hover:opacity-100">Services</a></li>
          <li><a href="/accommodation/" class="text-sm text-sky-water hover:text-sea-salt no-underline opacity-80 hover:opacity-100">Stay</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-sans font-semibold text-sea-salt text-sm uppercase tracking-wider mb-3">
          Contact
        </h3>
        <ul class="flex flex-col gap-2 list-none text-sm opacity-80">
          {config?.whatsapp && (
            <li>
              <a
                href={`https://wa.me/${config.whatsapp}`}
                class="text-sky-water hover:text-sea-salt no-underline hover:opacity-100"
                target="_blank"
                rel="noopener noreferrer"
              >
                WhatsApp us
              </a>
            </li>
          )}
          {config?.phone && (
            <li>
              <a href={`tel:${config.phone}`} class="text-sky-water hover:text-sea-salt no-underline hover:opacity-100">
                {config.phone}
              </a>
            </li>
          )}
          {config?.email && (
            <li>
              <a href={`mailto:${config.email}`} class="text-sky-water hover:text-sea-salt no-underline hover:opacity-100">
                {config.email}
              </a>
            </li>
          )}
          {config?.instagramUrl && (
            <li>
              <a
                href={config.instagramUrl}
                class="text-sky-water hover:text-sea-salt no-underline hover:opacity-100"
                target="_blank"
                rel="noopener noreferrer"
              >
                Instagram
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-border text-xs opacity-60 flex flex-col md:flex-row justify-between gap-2">
      <p>&copy; {new Date().getFullYear()} Los Gigantes Guide. All rights reserved.</p>
      <p>
        {config?.address}
        {' · '}
        <a href="/credits/" class="underline hover:opacity-100">Photo credits</a>
      </p>
    </div>
  </div>
</footer>

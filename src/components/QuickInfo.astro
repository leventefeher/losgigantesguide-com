---
import Badge from '@components/ui/Badge.astro';

interface Props {
  status: 'open' | 'seasonal' | 'closed';
  seasonNote?: string;
  address?: string;
  phone?: string;
  whatsapp?: string;
  website?: string;
  openingHours?: string;
  priceRange?: string;
}

const {
  status,
  seasonNote,
  address,
  phone,
  whatsapp,
  website,
  openingHours,
  priceRange,
} = Astro.props;

const hasAnyInfo =
  address || phone || whatsapp || website || openingHours || priceRange;
---

{hasAnyInfo && (
  <aside
    class="bg-white border border-border rounded-xl p-5 not-prose"
    aria-label="Quick info"
  >
    <div class="flex items-center gap-2 mb-4">
      <Badge status={status} seasonNote={seasonNote} />
      {priceRange && (
        <span class="text-sm text-cliff-deep font-medium bg-sea-salt px-2 py-0.5 rounded-full border border-border">
          {priceRange}
        </span>
      )}
    </div>

    <dl class="flex flex-col gap-2.5 text-sm">
      {address && (
        <div class="flex gap-3">
          <dt class="font-semibold text-volcanic min-w-[80px] flex-shrink-0">Address</dt>
          <dd>
            <address class="not-italic text-cliff-deep leading-snug">{address}</address>
          </dd>
        </div>
      )}
      {openingHours && (
        <div class="flex gap-3">
          <dt class="font-semibold text-volcanic min-w-[80px] flex-shrink-0">Hours</dt>
          <dd class="text-cliff-deep">{openingHours}</dd>
        </div>
      )}
      {phone && (
        <div class="flex gap-3">
          <dt class="font-semibold text-volcanic min-w-[80px] flex-shrink-0">Phone</dt>
          <dd>
            <a href={`tel:${phone}`} class="text-cliff-deep no-underline hover:underline">
              {phone}
            </a>
          </dd>
        </div>
      )}
      {whatsapp && (
        <div class="flex gap-3">
          <dt class="font-semibold text-volcanic min-w-[80px] flex-shrink-0">WhatsApp</dt>
          <dd>
            <a
              href={`https://wa.me/${whatsapp}`}
              class="text-cliff-deep no-underline hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Message on WhatsApp
            </a>
          </dd>
        </div>
      )}
      {website && (
        <div class="flex gap-3">
          <dt class="font-semibold text-volcanic min-w-[80px] flex-shrink-0">Website</dt>
          <dd>
            <a
              href={website}
              class="text-cliff-deep no-underline hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Visit website ↗
            </a>
          </dd>
        </div>
      )}
    </dl>
  </aside>
)}

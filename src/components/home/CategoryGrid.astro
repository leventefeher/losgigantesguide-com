---
import { Image } from 'astro:assets';
import imgThingsToDo  from '@assets/images/categories/things-to-do.jpg';
import imgRestaurants from '@assets/images/categories/restaurants.jpg';
import imgServices    from '@assets/images/categories/services.jpg';
import imgStay        from '@assets/images/categories/stay.jpg';

const categories = [
  { label: 'Things to do',  href: '/activities/',    image: imgThingsToDo,  description: 'Whale watching, kayaking, boat trips, and more.' },
  { label: 'Restaurants',   href: '/restaurants/',    image: imgRestaurants, description: 'Fresh fish, local tapas, and the places the locals eat.' },
  { label: 'Services',      href: '/services/',       image: imgServices,    description: 'Reliable tradespeople, photographers, and local pros.' },
  { label: 'Stay',          href: '/accommodation/',  image: imgStay,        description: 'Self-catering apartments and accommodation that works for longer.' },
];
---

<section class="py-16 px-4 bg-sea-salt">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-serif text-cliff-deep font-bold text-center mb-10" style="font-size: clamp(1.5rem, 3vw, 2rem);">
      What's here
    </h2>
    <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 list-none p-0 m-0" role="list">
      {categories.map(({ label, href, image, description }) => (
        <li>
          <a
            href={href}
            class="group block rounded-xl overflow-hidden no-underline relative shadow-sm hover:shadow-md transition-shadow"
          >
            <Image
              src={image}
              alt=""
              width={400}
              height={260}
              formats={['avif', 'webp']}
              loading="lazy"
              class="w-full h-44 object-cover transition-transform duration-300 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-volcanic/90 via-volcanic/40 to-transparent" aria-hidden="true" />
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="font-serif font-bold text-sea-salt text-lg leading-snug mb-1">
                {label}
              </h3>
              <p class="text-sky-water text-xs leading-relaxed line-clamp-2">{description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

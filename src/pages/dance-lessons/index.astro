---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';

const entries = await getCollection('dance-lessons');
const lesson = entries[0]; // Primary dance lesson entry

const siteConfigs = await getCollection('siteConfig');
const config = siteConfigs[0]?.data;

const whatsapp = lesson?.data.whatsapp ?? config?.whatsapp;
---

<BaseLayout
  title="Salsa & Bachata Dance Lessons in Los Gigantes"
  description="Friendly salsa and bachata classes in Los Gigantes, Tenerife. Beginners welcome, no partner needed. Small groups, local instructor."
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-8">
      <span class="inline-block bg-sunset-coral text-sea-salt text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4">
        Dance lessons
      </span>
      <h1 class="font-serif font-bold text-cliff-deep mb-4" style="font-size: clamp(1.8rem, 4vw, 2.5rem);">
        Salsa &amp; Bachata<br />in Los Gigantes
      </h1>
      <p class="text-atlantic text-lg leading-relaxed max-w-xl">
        Small-group classes run by a local who actually dances socially — not a performance coach. Beginners welcome, no partner needed.
      </p>
    </div>

    {lesson && (
      <>
        <!-- Status -->
        <div class="flex items-center gap-3 mb-8">
          <Badge status={lesson.data.status} seasonNote={lesson.data.seasonNote} />
          {lesson.data.priceRange && (
            <span class="text-sm text-atlantic">{lesson.data.priceRange} per class</span>
          )}
        </div>

        <!-- Quick details -->
        <div class="bg-white border border-border rounded-xl p-6 mb-8">
          <h2 class="font-sans font-semibold text-cliff-deep text-sm uppercase tracking-wider mb-4">
            Class details
          </h2>
          <dl class="flex flex-col gap-3">
            <div class="flex gap-4">
              <dt class="font-semibold text-sm min-w-[100px] text-volcanic">When</dt>
              <dd class="text-sm text-atlantic">{lesson.data.schedule}</dd>
            </div>
            <div class="flex gap-4">
              <dt class="font-semibold text-sm min-w-[100px] text-volcanic">Level</dt>
              <dd class="text-sm text-atlantic">
                {lesson.data.level.map((l) => l.replace('-', ' ')).join(', ')}
              </dd>
            </div>
            {lesson.data.address && (
              <div class="flex gap-4">
                <dt class="font-semibold text-sm min-w-[100px] text-volcanic">Where</dt>
                <dd class="text-sm text-atlantic">{lesson.data.address}</dd>
              </div>
            )}
          </dl>
        </div>

        <!-- Advisory note -->
        <div class="bg-golden-hour/10 border border-golden-hour/30 rounded-xl p-4 mb-8 text-sm text-volcanic">
          <strong>Always confirm via WhatsApp before attending</strong> — schedules change when I'm travelling or the hall is booked for another event.
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          {whatsapp && (
            <Button href={`https://wa.me/${whatsapp}?text=Hi!%20I'd%20like%20to%20join%20a%20dance%20class`} variant="primary">
              WhatsApp to book
            </Button>
          )}
          {lesson.data.phone && (
            <Button href={`tel:${lesson.data.phone}`} variant="secondary">
              Call {lesson.data.phone}
            </Button>
          )}
        </div>

        <!-- Full content -->
        {await (async () => {
          const { Content } = await render(lesson);
          return <div class="prose max-w-none text-cliff-deep"><Content /></div>;
        })()}
      </>
    )}
  </div>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import QuickInfo from '@components/QuickInfo.astro';
import RelatedListings from '@components/RelatedListings.astro';
import Button from '@components/ui/Button.astro';

export async function getStaticPaths() {
  const entries = await getCollection('services');
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry, allEntries: entries },
  }));
}

const { entry, allEntries } = Astro.props;
const {
  title, description, coverImage, coverImageAlt, address, phone, website,
  status, seasonNote, priceRange, tags, whatsapp,
} = entry.data;

const { Content } = await render(entry);
const canonicalUrl = new URL(`/services/${entry.id}/`, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: title,
  description,
  url: canonicalUrl,
  ...(address ? { address: { '@type': 'PostalAddress', streetAddress: address } } : {}),
  ...(phone ? { telephone: phone } : {}),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Services', href: '/services/' },
        { label: title },
      ]}
    />

    <h1 class="font-serif font-bold text-cliff-deep mb-6" style="font-size: clamp(1.8rem, 4vw, 2.5rem);">
      {title}
    </h1>

    {coverImage && (
      <Image
        src={coverImage}
        alt={coverImageAlt ?? ''}
        width={900}
        height={500}
        loading="eager"
        decoding="sync"
        formats={['avif', 'webp']}
        class="w-full rounded-xl mb-8 object-cover"
        style="max-height: 500px;"
      />
    )}

    {whatsapp && (
      <div class="mb-6">
        <Button href={`https://wa.me/${whatsapp}`} variant="primary">
          WhatsApp for a quote
        </Button>
      </div>
    )}

    <div class="grid md:grid-cols-[1fr_280px] gap-8 items-start">
      <div class="prose max-w-none text-cliff-deep">
        <Content />
      </div>
      <div class="flex flex-col gap-4">
        <QuickInfo
          status={status}
          seasonNote={seasonNote}
          address={address}
          phone={phone}
          whatsapp={whatsapp}
          website={website}
          priceRange={priceRange}
        />
      </div>
    </div>

    {tags.length > 0 && (
      <div class="mt-8 pt-6 border-t border-border">
        <p class="text-xs font-semibold uppercase tracking-wider text-atlantic mb-3">Tagged:</p>
        <ul class="flex flex-wrap gap-2 list-none p-0 m-0" role="list">
          {tags.map((tag) => (
            <li>
              <a href={`/tags/${tag}/`} class="text-sm text-atlantic no-underline bg-sea-salt border border-border px-3 py-1 rounded-full hover:bg-sea-salt-dark">
                {tag}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <RelatedListings
      currentId={entry.id}
      currentTags={tags}
      entries={allEntries}
      categorySlug="services"
    />
  </div>
</BaseLayout>

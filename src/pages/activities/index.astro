---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import PlaceCard from "@components/PlaceCard.astro";

const allEntries = await getCollection("activities");

// Partition: open/seasonal first, closed last
const active = allEntries.filter((e) => e.data.status !== "closed");
const closed = allEntries.filter((e) => e.data.status === "closed");
const entries = [...active, ...closed];

// Unique tags across all entries
const allTags = [...new Set(entries.flatMap((e) => e.data.tags))].sort();
---

<BaseLayout
  title="Things to Do in Los Gigantes"
  description="The best activities in Los Gigantes, Tenerife — whale watching, sea kayaking, coastal walks and more. Honest local recommendations."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <h1
      class="font-serif font-bold text-cliff-deep mb-3"
      style="font-size: clamp(1.8rem, 4vw, 2.5rem);"
    >
      Things to Do in Los Gigantes
    </h1>
    <p class="text-atlantic text-lg mb-6 max-w-2xl">
      Activities worth doing in and around Los Gigantes, Tenerife — from the
      iconic cliffs to quiet walks with no one else around.
    </p>

    {
      allTags.length > 0 && (
        <nav aria-label="Filter by tag" class="mb-8">
          <ul
            class="flex flex-wrap gap-2 list-none p-0 m-0"
            role="list"
            id="tag-filters"
          >
            <li>
              <button
                data-tag="all"
                class="tag-btn text-sm no-underline bg-cliff-deep text-sea-salt border border-cliff-deep px-3 py-1 rounded-full transition-colors cursor-pointer"
                aria-pressed="true"
              >
                All
              </button>
            </li>
            {allTags.map((tag) => (
              <li>
                <button
                  data-tag={tag}
                  class="tag-btn text-sm text-atlantic bg-sea-salt border border-border px-3 py-1 rounded-full hover:bg-sea-salt-dark transition-colors cursor-pointer"
                  aria-pressed="false"
                >
                  {tag}
                </button>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <ul
      class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 list-none p-0 m-0"
      role="list"
      id="activity-list"
    >
      {
        entries.map((entry) => (
          <li data-tags={entry.data.tags.join(",")}>
            <PlaceCard
              entry={entry}
              categorySlug="activities"
              headingLevel={2}
            />
          </li>
        ))
      }
    </ul>

    <p id="no-results" class="hidden text-atlantic mt-8">
      No activities found for this filter.
    </p>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const cards = document.querySelectorAll<HTMLLIElement>("#activity-list li");
  const noResults = document.getElementById("no-results")!;

  function applyFilter(selected: string) {
    // Update button states
    buttons.forEach((btn) => {
      const isActive = btn.dataset.tag === selected;
      btn.setAttribute("aria-pressed", String(isActive));
      if (isActive) {
        btn.classList.add(
          "bg-cliff-deep",
          "text-sea-salt",
          "border-cliff-deep",
        );
        btn.classList.remove("bg-sea-salt", "text-atlantic", "border-border");
      } else {
        btn.classList.remove(
          "bg-cliff-deep",
          "text-sea-salt",
          "border-cliff-deep",
        );
        btn.classList.add("bg-sea-salt", "text-atlantic", "border-border");
      }
    });

    // Show/hide cards
    let visible = 0;
    cards.forEach((card) => {
      const tags = card.dataset.tags?.split(",") ?? [];
      const show = selected === "all" || tags.includes(selected);
      card.hidden = !show;
      if (show) visible++;
    });

    noResults.classList.toggle("hidden", visible > 0);
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => applyFilter(btn.dataset.tag ?? "all"));
  });
</script>

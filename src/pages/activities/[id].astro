---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import QuickInfo from '@components/QuickInfo.astro';
import RelatedListings from '@components/RelatedListings.astro';

export async function getStaticPaths() {
  const entries = await getCollection('activities');
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry, allEntries: entries },
  }));
}

const { entry, allEntries } = Astro.props;
const { title, description, coverImage, coverImageAlt, address, phone, website, status, seasonNote, priceRange, tags, lat, lng } =
  entry.data;

const { Content } = await render(entry);

const canonicalUrl = new URL(`/activities/${entry.id}/`, Astro.site).href;
const ogImageData = coverImage
  ? await getImage({ src: coverImage, width: 1200, height: 630, format: 'jpeg' })
  : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: title,
  description,
  url: canonicalUrl,
  ...(address ? { address: { '@type': 'PostalAddress', streetAddress: address } } : {}),
  ...(phone ? { telephone: phone } : {}),
  ...(lat && lng ? { geo: { '@type': 'GeoCoordinates', latitude: lat, longitude: lng } } : {}),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImageData?.src}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Things to do', href: '/activities/' },
        { label: title },
      ]}
    />

    <h1 class="font-serif font-bold text-cliff-deep mb-6" style="font-size: clamp(1.8rem, 4vw, 2.5rem);">
      {title}
    </h1>

    {coverImage && (
      <Image
        src={coverImage}
        alt={coverImageAlt ?? ''}
        width={900}
        height={500}
        loading="eager"
        decoding="sync"
        formats={['avif', 'webp']}
        class="w-full rounded-xl mb-8 object-cover"
        style="max-height: 500px;"
      />
    )}

    <div class="grid md:grid-cols-[1fr_280px] gap-8 items-start">
      <!-- Main content -->
      <div class="prose max-w-none text-cliff-deep">
        <Content />
      </div>

      <!-- Sidebar -->
      <div class="flex flex-col gap-4">
        <QuickInfo
          status={status}
          seasonNote={seasonNote}
          address={address}
          phone={phone}
          website={website}
          priceRange={priceRange}
        />
      </div>
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="mt-8 pt-6 border-t border-border">
        <p class="text-xs font-semibold uppercase tracking-wider text-atlantic mb-3">Tagged:</p>
        <ul class="flex flex-wrap gap-2 list-none p-0 m-0" role="list">
          {tags.map((tag) => (
            <li>
              <a
                href={`/tags/${tag}/`}
                class="text-sm text-atlantic no-underline bg-sea-salt border border-border px-3 py-1 rounded-full hover:bg-sea-salt-dark"
              >
                {tag}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <RelatedListings
      currentId={entry.id}
      currentTags={tags}
      entries={allEntries}
      categorySlug="activities"
    />
  </div>
</BaseLayout>

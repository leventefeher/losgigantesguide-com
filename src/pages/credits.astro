---
import BaseLayout from "@layouts/BaseLayout.astro";
import credits from "../data/photo-credits.json";
---

<BaseLayout
  title="Photo Credits"
  description="Attributions for photographs used on Los Gigantes Guide."
  noindex={true}
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1
      class="font-serif font-bold text-cliff-deep mb-3"
      style="font-size: clamp(1.8rem, 4vw, 2.5rem);"
    >
      Photo Credits
    </h1>
    <p class="text-cliff-deep mb-10">
      All photographs used on this site are licensed under their respective
      terms. Attributions are listed below.
    </p>

    <ul class="flex flex-col gap-4 list-none p-0" role="list">
      {
        credits.map((credit) => (
          <li class="bg-white border border-border rounded-xl px-5 py-4">
            <p class="text-sm text-volcanic font-medium mb-1">
              {credit.description}
            </p>
            <p class="text-sm text-cliff-deep">
              Photo by{" "}
              <a
                href={credit.photographerUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                {credit.photographer}
              </a>{" "}
              on{" "}
              <a
                href={credit.sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                {credit.source}
              </a>
            </p>
          </li>
        ))
      }
    </ul>

    {credits.length === 0 && <p class="text-cliff-deep">No photo credits yet.</p>}
  </div>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PlaceCard from '@components/PlaceCard.astro';

const allEntries = await getCollection('fitness');
const active = allEntries.filter((e) => e.data.status !== 'closed');
const closed = allEntries.filter((e) => e.data.status === 'closed');
const entries = [...active, ...closed];
const allTags = [...new Set(entries.flatMap((e) => e.data.tags))].sort();
---

<BaseLayout
  title="Fitness in Los Gigantes"
  description="Stay active during your stay — outdoor bootcamps, yoga, and fitness classes in and around Los Gigantes, Tenerife."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="font-serif font-bold text-cliff-deep mb-3" style="font-size: clamp(1.8rem, 4vw, 2.5rem);">
      Fitness in Los Gigantes
    </h1>
    <p class="text-atlantic text-lg mb-8 max-w-2xl">
      Stay active during your stay. Outdoor classes, yoga, and fitness sessions that make the most of the setting.
    </p>

    {allTags.length > 0 && (
      <nav aria-label="Filter by tag" class="mb-8">
        <ul class="flex flex-wrap gap-2 list-none p-0 m-0" role="list" id="tag-filters">
          <li>
            <button data-tag="all" class="tag-btn text-sm bg-cliff-deep text-sea-salt border border-cliff-deep px-3 py-1 rounded-full transition-colors cursor-pointer" aria-pressed="true">All</button>
          </li>
          {allTags.map((tag) => (
            <li>
              <button data-tag={tag} class="tag-btn text-sm text-atlantic bg-sea-salt border border-border px-3 py-1 rounded-full hover:bg-sea-salt-dark transition-colors cursor-pointer" aria-pressed="false">{tag}</button>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 list-none p-0 m-0" role="list" id="entry-list">
      {entries.map((entry) => (
        <li data-tags={entry.data.tags.join(',')}>
          <PlaceCard entry={entry} categorySlug="fitness" headingLevel={2} />
        </li>
      ))}
    </ul>
    <p id="no-results" class="hidden text-atlantic mt-8">No results for this filter.</p>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards = document.querySelectorAll<HTMLLIElement>('#entry-list li');
  const noResults = document.getElementById('no-results')!;

  function applyFilter(selected: string) {
    buttons.forEach((btn) => {
      const isActive = btn.dataset.tag === selected;
      btn.setAttribute('aria-pressed', String(isActive));
      if (isActive) {
        btn.classList.add('bg-cliff-deep', 'text-sea-salt', 'border-cliff-deep');
        btn.classList.remove('bg-sea-salt', 'text-atlantic', 'border-border');
      } else {
        btn.classList.remove('bg-cliff-deep', 'text-sea-salt', 'border-cliff-deep');
        btn.classList.add('bg-sea-salt', 'text-atlantic', 'border-border');
      }
    });
    let visible = 0;
    cards.forEach((card) => {
      const tags = card.dataset.tags?.split(',') ?? [];
      const show = selected === 'all' || tags.includes(selected);
      card.hidden = !show;
      if (show) visible++;
    });
    noResults.classList.toggle('hidden', visible > 0);
  }

  buttons.forEach((btn) => btn.addEventListener('click', () => applyFilter(btn.dataset.tag ?? 'all')));
</script>

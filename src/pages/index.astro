---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/home/Hero.astro';
import CategoryGrid from '@components/home/CategoryGrid.astro';
import FeaturedListings from '@components/home/FeaturedListings.astro';
import heroImage from '@assets/images/heroes/maksim-shutov-unsplash-clifs-with-boat.jpg';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Los Gigantes Guide',
  url: 'https://losgigantesguide.com',
  description:
    'Local tips, honest reviews, and hidden spots for Los Gigantes, Tenerife. Things to do, restaurants, services, accommodation, and dance lessons.',
  inLanguage: 'en',
};
---

<BaseLayout
  title="Los Gigantes Guide"
  description="Your local guide to Los Gigantes, Tenerife. Honest recommendations for things to do, restaurants, services, accommodation, and dance lessons."
  jsonLd={websiteJsonLd}
>
  <Hero image={heroImage} imageAlt="The Los Gigantes cliffs with a boat in the foreground" />
  <CategoryGrid />
  <FeaturedListings />
</BaseLayout>

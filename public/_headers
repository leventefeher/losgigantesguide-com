# Cloudflare Pages HTTP headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Astro-fingerprinted assets — immutable cache (filenames change on content change)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts (served from _astro/ by Astro build, but belt-and-suspenders)
/fonts/*
  Cache-Control: public, max-age=604800

# Images in public/
/images/*
  Cache-Control: public, max-age=604800

# HTML pages — always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*/
  Cache-Control: public, max-age=0, must-revalidate

# Security headers — applied to all routes
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # Fonts are self-hosted via @fontsource — no CDN, no fonts.gstatic.com needed
  # If Google Maps embed is added later, add: frame-src https://www.google.com
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' https://www.googletagmanager.com 'unsafe-inline'; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com
